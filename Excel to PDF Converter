    <script>
        // ===== FIREBASE CONFIGURATION =====
        // REPLACE THESE WITH YOUR ACTUAL FIREBASE CONFIG
        const firebaseConfig = {
            apiKey: "YOUR_API_KEY",
            authDomain: "YOUR_PROJECT_ID.firebaseapp.com",
            projectId: "YOUR_PROJECT_ID",
            storageBucket: "YOUR_PROJECT_ID.appspot.com",
            messagingSenderId: "YOUR_MESSAGING_SENDER_ID",
            appId: "YOUR_APP_ID"
        };

        // Initialize Firebase
        let firebaseApp, firebaseAuth, firebaseDb, firebaseStorage;
        let currentUser = null;
        let userHistory = [];

        // Try to initialize Firebase (will work when config is valid)
        try {
            firebaseApp = firebase.initializeApp(firebaseConfig);
            firebaseAuth = firebase.auth();
            firebaseDb = firebase.firestore();
            firebaseStorage = firebase.storage();
            console.log('Firebase initialized successfully');
        } catch (e) {
            console.log('Firebase not configured yet. Please add your Firebase config.');
        }

        // ===== GLOBAL STATE =====
        let currentTool = '';
        let uploadedFiles = [];
        let processedResult = null;
        let workbook = null;
        let sheetData = [];
        let currentSheet = 0;
        let undoStack = [];
        let redoStack = [];

        // ===== PARTICLES =====
        function createParticles() {
            const container = document.getElementById('particles');
            const colors = ['rgba(124,58,237,0.4)', 'rgba(6,182,212,0.4)', 'rgba(244,114,182,0.4)', 'rgba(251,191,36,0.4)'];
            for (let i = 0; i < 40; i++) {
                const p = document.createElement('div');
                p.className = 'particle';
                p.style.left = Math.random() * 100 + '%';
                p.style.animationDelay = Math.random() * 20 + 's';
                p.style.animationDuration = (12 + Math.random() * 10) + 's';
                p.style.width = (2 + Math.random() * 5) + 'px';
                p.style.height = p.style.width;
                p.style.background = colors[Math.floor(Math.random() * colors.length)];
                container.appendChild(p);
            }
        }
        createParticles();

        // ===== SIDEBAR =====
        function toggleSidebar() {
            document.getElementById('sidebar').classList.toggle('open');
            document.getElementById('sidebarOverlay').classList.toggle('active');
        }
        function closeSidebar() {
            document.getElementById('sidebar').classList.remove('open');
            document.getElementById('sidebarOverlay').classList.remove('active');
        }

        // ===== FIREBASE AUTH - GOOGLE SIGN IN =====
        function signInWithGoogle() {
            if (!firebaseAuth) {
                showToast('Firebase not configured. Please add your Firebase config first.', 'warning');
                // Demo mode - simulate login
                simulateLogin();
                return;
            }

            const provider = new firebase.auth.GoogleAuthProvider();
            firebaseAuth.signInWithPopup(provider)
                .then((result) => {
                    const user = result.user;
                    currentUser = user;
                    updateUIForUser(user);
                    saveUserToDatabase(user);
                    showToast('Welcome, ' + user.displayName + '!', 'success');
                })
                .catch((error) => {
                    showToast('Login failed: ' + error.message, 'error');
                });
        }

        function simulateLogin() {
            // Demo mode - create a fake user for testing
            currentUser = {
                uid: 'demo-user-' + Date.now(),
                displayName: 'Demo User',
                email: 'demo@example.com',
                photoURL: 'https://ui-avatars.com/api/?name=Demo+User&background=7c3aed&color=fff'
            };
            updateUIForUser(currentUser);
            showToast('Demo mode: Logged in as ' + currentUser.displayName, 'info');

            // Save to localStorage for demo
            localStorage.setItem('pdfMasterUser', JSON.stringify({
                uid: currentUser.uid,
                name: currentUser.displayName,
                email: currentUser.email,
                photoURL: currentUser.photoURL,
                loginTime: new Date().toISOString()
            }));
        }

        function signOut() {
            if (firebaseAuth) {
                firebaseAuth.signOut();
            }
            currentUser = null;
            userHistory = [];
            localStorage.removeItem('pdfMasterUser');
            updateUIForGuest();
            showToast('Signed out successfully', 'info');
        }

        function updateUIForUser(user) {
            document.getElementById('loginBtn').style.display = 'none';
            document.getElementById('userProfile').style.display = 'flex';
            document.getElementById('userAvatar').src = user.photoURL || 'https://ui-avatars.com/api/?name=' + encodeURIComponent(user.displayName) + '&background=7c3aed&color=fff';
            document.getElementById('userName').textContent = user.displayName || 'User';

            // Show user stats and history
            document.getElementById('userStats').style.display = 'grid';
            document.getElementById('userHistoryPanel').style.display = 'block';

            // Load user history
            loadUserHistory(user.uid);
        }

        function updateUIForGuest() {
            document.getElementById('loginBtn').style.display = 'flex';
            document.getElementById('userProfile').style.display = 'none';
            document.getElementById('userStats').style.display = 'none';
            document.getElementById('userHistoryPanel').style.display = 'none';
        }

        // ===== SAVE USER TO DATABASE =====
        async function saveUserToDatabase(user) {
            if (!firebaseDb) return;

            try {
                await firebaseDb.collection('users').doc(user.uid).set({
                    uid: user.uid,
                    name: user.displayName,
                    email: user.email,
                    photoURL: user.photoURL,
                    lastLogin: firebase.firestore.FieldValue.serverTimestamp(),
                    totalFiles: 0,
                    totalToolsUsed: 0,
                    createdAt: firebase.firestore.FieldValue.serverTimestamp()
                }, { merge: true });
                console.log('User saved to database');
            } catch (e) {
                console.error('Error saving user:', e);
            }
        }

        // ===== SAVE USER ACTIVITY =====
        async function saveUserActivity(toolName, fileName, fileSize, status) {
            if (!currentUser) return;

            const activity = {
                userId: currentUser.uid,
                userName: currentUser.displayName,
                userEmail: currentUser.email,
                toolName: toolName,
                fileName: fileName,
                fileSize: fileSize,
                status: status,
                timestamp: new Date().toISOString(),
                device: navigator.userAgent,
                ip: 'client-side' // Actual IP needs server
            };

            // Save to Firebase if available
            if (firebaseDb) {
                try {
                    await firebaseDb.collection('userActivities').add({
                        ...activity,
                        createdAt: firebase.firestore.FieldValue.serverTimestamp()
                    });

                    // Update user stats
                    await firebaseDb.collection('users').doc(currentUser.uid).update({
                        totalFiles: firebase.firestore.FieldValue.increment(1),
                        lastActive: firebase.firestore.FieldValue.serverTimestamp()
                    });
                } catch (e) {
                    console.error('Error saving activity:', e);
                }
            }

            // Always save to localStorage as backup
            let localHistory = JSON.parse(localStorage.getItem('pdfMasterHistory') || '[]');
            localHistory.unshift(activity);
            if (localHistory.length > 100) localHistory = localHistory.slice(0, 100);
            localStorage.setItem('pdfMasterHistory', JSON.stringify(localHistory));

            // Update UI
            userHistory.unshift(activity);
            renderUserHistory();
            updateUserStats();
        }

        // ===== LOAD USER HISTORY =====
        async function loadUserHistory(userId) {
            if (!userId) return;

            // Try Firebase first
            if (firebaseDb) {
                try {
                    const snapshot = await firebaseDb.collection('userActivities')
                        .where('userId', '==', userId)
                        .orderBy('createdAt', 'desc')
                        .limit(50)
                        .get();

                    userHistory = snapshot.docs.map(doc => doc.data());
                    renderUserHistory();
                    updateUserStats();
                    return;
                } catch (e) {
                    console.log('Using local history instead');
                }
            }

            // Fallback to localStorage
            const localHistory = JSON.parse(localStorage.getItem('pdfMasterHistory') || '[]');
            userHistory = localHistory.filter(h => h.userId === userId);
            renderUserHistory();
            updateUserStats();
        }

        // ===== RENDER USER HISTORY =====
        function renderUserHistory() {
            const container = document.getElementById('historyList');
            if (!container) return;

            if (userHistory.length === 0) {
                container.innerHTML = '<p style="text-align:center;color:var(--gray);padding:20px;">No activity yet. Start using tools!</p>';
                return;
            }

            let html = '';
            userHistory.slice(0, 20).forEach(item => {
                const date = new Date(item.timestamp);
                const dateStr = date.toLocaleDateString() + ' ' + date.toLocaleTimeString();
                const statusClass = item.status === 'Success' ? 'status-success' : item.status === 'Pending' ? 'status-pending' : 'status-error';
                const icon = getToolIcon(item.toolName);

                html += '<div class="history-item">';
                html += '<div class="history-info">';
                html += '<i class="fas ' + icon + '"></i>';
                html += '<div class="history-details">';
                html += '<div class="tool-name">' + item.toolName + '</div>';
                html += '<div class="file-name">' + item.fileName + ' (' + item.fileSize + ')</div>';
                html += '</div></div>';
                html += '<div class="history-meta">';
                html += '<div class="date">' + dateStr + '</div>';
                html += '<span class="status ' + statusClass + '">' + item.status + '</span>';
                html += '</div></div>';
            });

            container.innerHTML = html;
        }

        function getToolIcon(toolName) {
            const icons = {
                'Merge PDF': 'fa-object-group', 'Split PDF': 'fa-cut',
                'Compress PDF': 'fa-compress-alt', 'JPG to PDF': 'fa-image',
                'Word to PDF': 'fa-file-word', 'Excel to PDF': 'fa-file-excel',
                'PDF to JPG': 'fa-image', 'PDF to Word': 'fa-file-word',
                'Rotate PDF': 'fa-sync-alt', 'Add Watermark': 'fa-tint',
                'Protect PDF': 'fa-lock', 'Unlock PDF': 'fa-lock-open'
            };
            return icons[toolName] || 'fa-file';
        }

        // ===== UPDATE USER STATS =====
        function updateUserStats() {
            const totalFiles = userHistory.length;
            const uniqueTools = new Set(userHistory.map(h => h.toolName)).size;
            const successCount = userHistory.filter(h => h.status === 'Success').length;
            const successRate = totalFiles > 0 ? Math.round((successCount / totalFiles) * 100) : 0;

            document.getElementById('statTotalFiles').textContent = totalFiles;
            document.getElementById('statTotalTools').textContent = uniqueTools;
            document.getElementById('statSuccessRate').textContent = successRate + '%';

            if (userHistory.length > 0) {
                const lastDate = new Date(userHistory[0].timestamp);
                const today = new Date();
                const diffDays = Math.floor((today - lastDate) / (1000 * 60 * 60 * 24));
                document.getElementById('statLastActive').textContent = diffDays === 0 ? 'Today' : diffDays === 1 ? 'Yesterday' : diffDays + ' days ago';
            }
        }

        // ===== CHECK EXISTING LOGIN =====
        function checkExistingLogin() {
            // Check Firebase auth state
            if (firebaseAuth) {
                firebaseAuth.onAuthStateChanged((user) => {
                    if (user) {
                        currentUser = user;
                        updateUIForUser(user);
                    } else {
                        // Check localStorage for demo user
                        const demoUser = localStorage.getItem('pdfMasterUser');
                        if (demoUser) {
                            const parsed = JSON.parse(demoUser);
                            currentUser = {
                                uid: parsed.uid,
                                displayName: parsed.name,
                                email: parsed.email,
                                photoURL: parsed.photoURL
                            };
                            updateUIForUser(currentUser);
                        } else {
                            updateUIForGuest();
                        }
                    }
                });
            } else {
                // Check localStorage only
                const demoUser = localStorage.getItem('pdfMasterUser');
                if (demoUser) {
                    const parsed = JSON.parse(demoUser);
                    currentUser = {
                        uid: parsed.uid,
                        displayName: parsed.name,
                        email: parsed.email,
                        photoURL: parsed.photoURL
                    };
                    updateUIForUser(currentUser);
                }
            }
        }

        // Run on load
        checkExistingLogin();

