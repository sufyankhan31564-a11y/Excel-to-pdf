                'summaryLength': '<div class="setting-group"><h4>Summary Length</h4><div class="setting-item"><select id="summaryLength"><option value="short">Short</option><option value="medium" selected>Medium</option><option value="long">Long</option></select></div></div>',
                'sourceLang': '<div class="setting-group"><h4>Source Language</h4><div class="setting-item"><select id="sourceLang"><option value="auto">Auto Detect</option><option value="en">English</option><option value="es">Spanish</option><option value="fr">French</option><option value="de">German</option><option value="hi">Hindi</option></select></div></div>',
                'targetLang': '<div class="setting-group"><h4>Target Language</h4><div class="setting-item"><select id="targetLang"><option value="en">English</option><option value="es">Spanish</option><option value="fr">French</option><option value="de">German</option><option value="hi">Hindi</option><option value="zh">Chinese</option><option value="ja">Japanese</option></select></div></div>'
            };

            let html = '';
            settings.forEach(s => { if (settingsHTML[s]) html += settingsHTML[s]; });
            grid.innerHTML = html;
            document.getElementById('settingsPanel').style.display = 'block';
        }

        function goHome() {
            document.getElementById('workspace').style.display = 'none';
            document.getElementById('homeView').style.display = 'block';
            document.getElementById('pageTitle').textContent = 'PDF Master Pro';
            currentTool = '';
            uploadedFiles = [];
            processedResult = null;
        }

        // ===== FILE HANDLING =====
        function handleFileSelect(event) {
            const files = Array.from(event.target.files);
            const config = toolConfig[currentTool];
            if (!config) return;

            files.forEach(file => {
                uploadedFiles.push(file);
                addFileToList(file);
            });

            showToast(files.length + ' file(s) uploaded', 'success');

            if (currentTool === 'excel-to-pdf') {
                processExcelFile(files[0]);
            }
        }

        function addFileToList(file) {
            const list = document.getElementById('fileList');
            const item = document.createElement('div');
            item.className = 'file-list-item';
            const icon = getFileIcon(file.name);
            item.innerHTML = '<div class="file-info"><i class="fas ' + icon + '" style="color: var(--primary-light);"></i><span>' + file.name + ' (' + formatFileSize(file.size) + ')</span></div><button class="remove-btn" onclick="removeFile(this)"><i class="fas fa-times"></i></button>';
            list.appendChild(item);
        }

        function removeFile(btn) {
            const item = btn.closest('.file-list-item');
            const index = Array.from(item.parentNode.children).indexOf(item);
            uploadedFiles.splice(index, 1);
            item.remove();
        }

        function getFileIcon(filename) {
            const ext = filename.split('.').pop().toLowerCase();
            const icons = {
                'pdf': 'fa-file-pdf', 'doc': 'fa-file-word', 'docx': 'fa-file-word',
                'xls': 'fa-file-excel', 'xlsx': 'fa-file-excel', 'csv': 'fa-file-csv',
                'ppt': 'fa-file-powerpoint', 'pptx': 'fa-file-powerpoint',
                'jpg': 'fa-file-image', 'jpeg': 'fa-file-image', 'png': 'fa-file-image',
                'html': 'fa-html5', 'htm': 'fa-html5'
            };
            return icons[ext] || 'fa-file';
        }

        function formatFileSize(bytes) {
            if (bytes === 0) return '0 B';
            const k = 1024;
            const sizes = ['B', 'KB', 'MB', 'GB'];
            const i = Math.floor(Math.log(bytes) / Math.log(k));
            return parseFloat((bytes / Math.pow(k, i)).toFixed(1)) + ' ' + sizes[i];
        }

        // ===== EXCEL PROCESSING =====
        function processExcelFile(file) {
            showProgress(10, 'Reading Excel file...');
            const reader = new FileReader();
            reader.onload = function(e) {
                showProgress(40, 'Parsing data...');
                const data = new Uint8Array(e.target.result);
                workbook = XLSX.read(data, { type: 'array' });

                setTimeout(() => {
                    showProgress(70, 'Loading spreadsheet...');
                    loadSheet(0);
                    showProgress(100, 'Ready!');
                    setTimeout(() => {
                        hideProgress();
                        showToast('Excel file loaded! Edit and export to PDF.', 'success');
                    }, 500);
                }, 300);
            };
            reader.readAsArrayBuffer(file);
        }

        function loadSheet(index) {
            currentSheet = index;
            const sheetName = workbook.SheetNames[index];
            const worksheet = workbook.Sheets[sheetName];
            const jsonData = XLSX.utils.sheet_to_json(worksheet, { header: 1, defval: '' });
            sheetData = jsonData.map(row => [...row]);
            renderSpreadsheet();
        }

        function renderSpreadsheet() {
            const container = document.getElementById('previewArea');
            container.style.display = 'block';

            if (sheetData.length === 0) {
                container.innerHTML = '<p style="text-align:center;color:#999;">Empty sheet</p>';
                return;
            }

            const maxCols = Math.max(...sheetData.map(row => row.length), 1);
            let html = '<div class="spreadsheet-container" style="display:block;"><table>';

            html += '<thead><tr><th>#</th>';
            for (let i = 0; i < maxCols; i++) html += '<th>' + getColumnLetter(i) + '</th>';
            html += '</tr></thead><tbody>';

            for (let i = 0; i < sheetData.length; i++) {
                html += '<tr><td style="background:var(--dark-light);color:var(--gray);text-align:center;font-weight:500;">' + (i + 1) + '</td>';
                for (let j = 0; j < maxCols; j++) {
                    const val = sheetData[i][j] !== undefined ? escapeHtml(String(sheetData[i][j])) : '';
                    html += '<td contenteditable="true" onblur="updateCell(this,' + i + ',' + j + ')">' + val + '</td>';
                }
                html += '</tr>';
            }
            html += '</tbody></table></div>';

            html += '<div style="display:flex;gap:10px;margin-top:15px;flex-wrap:wrap;">';
            html += '<button class="btn btn-secondary" onclick="addRow()"><i class="fas fa-plus"></i> Add Row</button>';
            html += '<button class="btn btn-secondary" onclick="addColumn()"><i class="fas fa-plus"></i> Add Column</button>';
            html += '<button class="btn btn-secondary" onclick="sortAscending()"><i class="fas fa-sort-alpha-down"></i> Sort A-Z</button>';
            html += '<button class="btn btn-secondary" onclick="sortDescending()"><i class="fas fa-sort-alpha-up"></i> Sort Z-A</button>';
            html += '<button class="btn btn-secondary" onclick="undoAction()"><i class="fas fa-undo"></i> Undo</button>';
            html += '</div>';

            container.innerHTML = html;
            document.getElementById('downloadBtn').style.display = 'inline-flex';
        }

        function getColumnLetter(index) {
            let result = '';
            index++;
            while (index > 0) {
                index--;
                result = String.fromCharCode(65 + (index % 26)) + result;
                index = Math.floor(index / 26);
            }
            return result;
        }

        function escapeHtml(text) {
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }

        function updateCell(cell, row, col) {
            saveState();
            while (sheetData.length <= row) sheetData.push([]);
            while (sheetData[row].length <= col) sheetData[row].push('');
            sheetData[row][col] = cell.textContent;
        }

        function addRow() {
            saveState();
            const maxCols = Math.max(...sheetData.map(row => row.length), 1);
            sheetData.push(new Array(maxCols).fill(''));
            renderSpreadsheet();
            showToast('Row added', 'success');
        }

        function addColumn() {
            saveState();
            sheetData.forEach(row => row.push(''));
            renderSpreadsheet();
            showToast('Column added', 'success');
        }

        function sortAscending() { sortData(true); }
        function sortDescending() { sortData(false); }
        function sortData(ascending) {
            if (sheetData.length < 2) return;
            saveState();
            const header = sheetData[0];
            const data = sheetData.slice(1);
            data.sort((a, b) => {
                const valA = String(a[0] || '').toLowerCase();
                const valB = String(b[0] || '').toLowerCase();
                if (!isNaN(valA) && !isNaN(valB)) {
                    return ascending ? Number(valA) - Number(valB) : Number(valB) - Number(valA);
                }
                return ascending ? valA.localeCompare(valB) : valB.localeCompare(valA);
            });
            sheetData = [header, ...data];
            renderSpreadsheet();
            showToast('Sorted ' + (ascending ? 'A-Z' : 'Z-A'), 'success');
        }

        function saveState() {
            undoStack.push(JSON.parse(JSON.stringify(sheetData)));
            if (undoStack.length > 50) undoStack.shift();
            redoStack = [];
        }

        function undoAction() {
            if (undoStack.length > 1) {
                redoStack.push(JSON.parse(JSON.stringify(sheetData)));
                undoStack.pop();
                sheetData = JSON.parse(JSON.stringify(undoStack[undoStack.length - 1]));
                renderSpreadsheet();
                showToast('Undo successful', 'success');
            }
        }

        // ===== PROCESS FILES =====
        async function processFiles() {
            if (uploadedFiles.length === 0) {
                showToast('Please upload a file first', 'warning');
                return;
            }

            const config = toolConfig[currentTool];
            const fileName = uploadedFiles[0].name;
            const fileSize = formatFileSize(uploadedFiles[0].size);

            showProgress(10, 'Starting...');

            try {
                switch(currentTool) {
                    case 'merge-pdf':
                        await mergePDFs();
                        break;
                    case 'split-pdf':
                        document.getElementById('pageRangeModal').classList.add('active');
                        hideProgress();
                        return;
                    case 'compress-pdf':
                        await compressPDF();
                        break;
                    case 'jpg-to-pdf':
                        await imagesToPDF();
                        break;
                    case 'excel-to-pdf':
                        await exportExcelToPDF();
                        break;
                    case 'rotate-pdf':
                        await rotatePDF();
                        break;
                    case 'add-watermark':
                        document.getElementById('watermarkModal').classList.add('active');
                        hideProgress();
                        return;
                    case 'protect-pdf':
                        document.getElementById('passwordModal').classList.add('active');
                        hideProgress();
                        return;
                    case 'unlock-pdf':
                        await unlockPDF();
                        break;
                    case 'repair-pdf':
                        await repairPDF();
                        break;
                    default:
                        showProgress(100, 'Done');
                        setTimeout(() => {
                            hideProgress();
                            showToast('Processing complete!', 'success');
                            document.getElementById('downloadBtn').style.display = 'inline-flex';
                        }, 500);
                }

                // Save activity after successful processing
                await saveUserActivity(config.name, fileName, fileSize, 'Success');

            } catch (error) {
                hideProgress();
                showToast('Error: ' + error.message, 'error');
                await saveUserActivity(config.name, fileName, fileSize, 'Error');
            }
        }

        // ===== PDF OPERATIONS =====
        async function mergePDFs() {
            showProgress(20, 'Loading PDFs...');
            const { PDFDocument } = PDFLib;
            const mergedPdf = await PDFDocument.create();

            for (let i = 0; i < uploadedFiles.length; i++) {
                showProgress(20 + (i / uploadedFiles.length) * 60, 'Merging page ' + (i + 1) + '...');
                const file = uploadedFiles[i];
                const arrayBuffer = await file.arrayBuffer();
                const pdf = await PDFDocument.load(arrayBuffer);
                const copiedPages = await mergedPdf.copyPages(pdf, pdf.getPageIndices());
                copiedPages.forEach(page => mergedPdf.addPage(page));
            }

            showProgress(90, 'Finalizing...');
            const mergedPdfFile = await mergedPdf.save();
            processedResult = new Blob([mergedPdfFile], { type: 'application/pdf' });

            showProgress(100, 'Complete!');
            setTimeout(() => {
                hideProgress();
                showToast('PDFs merged successfully!', 'success');
                document.getElementById('downloadBtn').style.display = 'inline-flex';
            }, 500);
        }

        async function compressPDF() {
            showProgress(30, 'Analyzing PDF...');
            const { PDFDocument } = PDFLib;
            const file = uploadedFiles[0];
            const arrayBuffer = await file.arrayBuffer();
            const pdf = await PDFDocument.load(arrayBuffer);

            showProgress(60, 'Compressing...');
            pdf.setTitle('');
            pdf.setAuthor('');
            pdf.setSubject('');
            pdf.setKeywords([]);
            pdf.setProducer('PDF Master Pro');
            pdf.setCreator('PDF Master Pro');

            showProgress(90, 'Saving...');
            const compressedPdf = await pdf.save({ useObjectStreams: true });
            processedResult = new Blob([compressedPdf], { type: 'application/pdf' });

            showProgress(100, 'Complete!');
            setTimeout(() => {
                hideProgress();
                const originalSize = file.size;
                const newSize = processedResult.size;
                const reduction = ((originalSize - newSize) / originalSize * 100).toFixed(1);
                showToast('Compressed! Size reduced by ' + reduction + '%', 'success');
                document.getElementById('downloadBtn').style.display = 'inline-flex';
            }, 500);
        }

        async function imagesToPDF() {
            showProgress(20, 'Loading images...');
            const { jsPDF } = window.jspdf;
            const orientation = document.getElementById('pageOrientation')?.value || 'portrait';
            const pageSize = document.getElementById('pageSize')?.value || 'a4';
            const margin = parseInt(document.getElementById('margin')?.value || '10');

            const doc = new jsPDF({ orientation: orientation, unit: 'mm', format: pageSize.toUpperCase() });

            for (let i = 0; i < uploadedFiles.length; i++) {
                showProgress(20 + (i / uploadedFiles.length) * 70, 'Processing image ' + (i + 1) + '...');
                const file = uploadedFiles[i];
                const imageUrl = URL.createObjectURL(file);

                await new Promise((resolve) => {
                    const img = new Image();
                    img.onload = function() {
                        const pageWidth = doc.internal.pageSize.getWidth() - margin * 2;
                        const pageHeight = doc.internal.pageSize.getHeight() - margin * 2;
                        const imgRatio = img.width / img.height;
                        const pageRatio = pageWidth / pageHeight;

                        let finalWidth, finalHeight;
                        if (imgRatio > pageRatio) {
                            finalWidth = pageWidth;
                            finalHeight = pageWidth / imgRatio;
                        } else {
                            finalHeight = pageHeight;
                            finalWidth = pageHeight * imgRatio;
                        }

                        const x = (doc.internal.pageSize.getWidth() - finalWidth) / 2;
                        const y = (doc.internal.pageSize.getHeight() - finalHeight) / 2;

                        doc.addImage(img, 'JPEG', x, y, finalWidth, finalHeight);
                        if (i < uploadedFiles.length - 1) doc.addPage();
                        resolve();
                    };
                    img.src = imageUrl;
                });
            }

            showProgress(95, 'Saving...');
            processedResult = doc.output('blob');

            showProgress(100, 'Complete!');
            setTimeout(() => {
                hideProgress();
                showToast('Images converted to PDF!', 'success');
                document.getElementById('downloadBtn').style.display = 'inline-flex';
            }, 500);
        }

        async function exportExcelToPDF() {
            showProgress(20, 'Preparing data...');
            const { jsPDF } = window.jspdf;
            const orientation = document.getElementById('pageOrientation')?.value || 'portrait';
            const pageSize = document.getElementById('pageSize')?.value || 'a4';
            const fontSize = parseInt(document.getElementById('fontSize')?.value || '10');
            const headerColor = document.getElementById('headerColor')?.value || '#7c3aed';

            const doc = new jsPDF({ orientation: orientation, unit: 'mm', format: pageSize.toUpperCase() });

            showProgress(50, 'Formatting...');
            const r = parseInt(headerColor.slice(1, 3), 16);
            const g = parseInt(headerColor.slice(3, 5), 16);
            const b = parseInt(headerColor.slice(5, 7), 16);

            const headers = sheetData.length > 0 ? sheetData[0].map((_, i) => getColumnLetter(i)) : [];
            const body = sheetData.length > 1 ? sheetData.slice(1) : [];

            showProgress(70, 'Generating PDF...');
            doc.autoTable({
                head: [headers],
                body: body,
                startY: 20,
                margin: { left: 10, right: 10, top: 10, bottom: 10 },
                theme: 'grid',
                headStyles: { fillColor: [r, g, b], textColor: 255, fontStyle: 'bold', fontSize: fontSize },
                bodyStyles: { fontSize: fontSize, textColor: 50 },
                alternateRowStyles: { fillColor: [250, 250, 250] },
                showHead: 'everyPage'
            });

            showProgress(95, 'Saving...');
            processedResult = doc.output('blob');

            showProgress(100, 'Complete!');
            setTimeout(() => {
                hideProgress();
                showToast('Excel exported to PDF!', 'success');
                document.getElementById('downloadBtn').style.display = 'inline-flex';
            }, 500);
        }

        async function rotatePDF() {
            showProgress(30, 'Loading PDF...');
            const { PDFDocument, degrees } = PDFLib;
            const file = uploadedFiles[0];
            const arrayBuffer = await file.arrayBuffer();
            const pdf = await PDFDocument.load(arrayBuffer);
            const angle = parseInt(document.getElementById('rotationAngle')?.value || '90');

            showProgress(60, 'Rotating pages...');
            pdf.getPages().forEach(page => {
                page.setRotation(degrees(angle));
            });

            showProgress(90, 'Saving...');
            const rotatedPdf = await pdf.save();
            processedResult = new Blob([rotatedPdf], { type: 'application/pdf' });

            showProgress(100, 'Complete!');
            setTimeout(() => {
                hideProgress();
                showToast('PDF rotated ' + angle + ' degrees!', 'success');
                document.getElementById('downloadBtn').style.display = 'inline-flex';
            }, 500);
        }

        async function unlockPDF() {
            showProgress(30, 'Processing...');
            const { PDFDocument } = PDFLib;
            const file = uploadedFiles[0];
            const arrayBuffer = await file.arrayBuffer();

            try {
                const pdf = await PDFDocument.load(arrayBuffer, { ignoreEncryption: true });
                showProgress(70, 'Removing protection...');
                const unlockedPdf = await pdf.save();
                processedResult = new Blob([unlockedPdf], { type: 'application/pdf' });

                showProgress(100, 'Complete!');
                setTimeout(() => {
                    hideProgress();
                    showToast('PDF unlocked successfully!', 'success');
                    document.getElementById('downloadBtn').style.display = 'inline-flex';
                }, 500);
            } catch (e) {
                hideProgress();
                showToast('Could not unlock PDF. It may be strongly encrypted.', 'error');
            }
        }

        async function repairPDF() {
            showProgress(30, 'Analyzing PDF...');
            const { PDFDocument } = PDFLib;
            const file = uploadedFiles[0];
            const arrayBuffer = await file.arrayBuffer();

            try {
                showProgress(50, 'Repairing structure...');
                const pdf = await PDFDocument.load(arrayBuffer, { updateMetadata: false });
                showProgress(80, 'Rebuilding...');
                const repairedPdf = await pdf.save({ useObjectStreams: true });
                processedResult = new Blob([repairedPdf], { type: 'application/pdf' });

                showProgress(100, 'Complete!');
                setTimeout(() => {
                    hideProgress();
                    showToast('PDF repaired successfully!', 'success');
                    document.getElementById('downloadBtn').style.display = 'inline-flex';
                }, 500);
            } catch (e) {
                hideProgress();
                showToast('Could not repair PDF. File may be severely corrupted.', 'error');
            }
        }

        // ===== MODAL CONFIRMATIONS =====
        function confirmPageRange() {
            const from = parseInt(document.getElementById('pageFrom').value);
            const to = parseInt(document.getElementById('pageTo').value);
            closeModal('pageRangeModal');

            showProgress(30, 'Splitting PDF...');
            setTimeout(async () => {
                const { PDFDocument } = PDFLib;
                const file = uploadedFiles[0];
                const arrayBuffer = await file.arrayBuffer();
                const pdf = await PDFDocument.load(arrayBuffer);

                const newPdf = await PDFDocument.create();
                const pageIndices = [];
                for (let i = from - 1; i < to && i < pdf.getPageCount(); i++) {
                    pageIndices.push(i);
                }

                showProgress(60, 'Extracting pages...');
                const copiedPages = await newPdf.copyPages(pdf, pageIndices);
                copiedPages.forEach(page => newPdf.addPage(page));

                showProgress(90, 'Saving...');
                const splitPdf = await newPdf.save();
                processedResult = new Blob([splitPdf], { type: 'application/pdf' });

                showProgress(100, 'Complete!');
                setTimeout(() => {
                    hideProgress();
                    showToast('PDF split successfully!', 'success');
                    document.getElementById('downloadBtn').style.display = 'inline-flex';
                }, 500);
            }, 300);
        }

        function confirmPassword() {
            const password = document.getElementById('pdfPassword').value;
            const confirm = document.getElementById('confirmPassword').value;
            if (password !== confirm) {
                showToast('Passwords do not match!', 'error');
                return;
            }
            closeModal('passwordModal');

            showProgress(30, 'Encrypting PDF...');
            setTimeout(async () => {
                const { PDFDocument } = PDFLib;
                const file = uploadedFiles[0];
                const arrayBuffer = await file.arrayBuffer();
                const pdf = await PDFDocument.load(arrayBuffer);

                showProgress(60, 'Applying protection...');
                const protectedPdf = await pdf.save({ useObjectStreams: false });
                processedResult = new Blob([protectedPdf], { type: 'application/pdf' });

                showProgress(100, 'Complete!');
                setTimeout(() => {
                    hideProgress();
                    showToast('PDF protected! (Demo: Use server for real encryption)', 'info');
                    document.getElementById('downloadBtn').style.display = 'inline-flex';
                }, 500);
            }, 300);
        }

        function confirmWatermark() {
            const text = document.getElementById('watermarkText').value;
            const opacity = document.getElementById('watermarkOpacity').value;
            const position = document.getElementById('watermarkPosition').value;
            closeModal('watermarkModal');

            showProgress(30, 'Adding watermark...');
            setTimeout(async () => {
                const { PDFDocument, rgb } = PDFLib;
                const file = uploadedFiles[0];
                const arrayBuffer = await file.arrayBuffer();
                const pdf = await PDFDocument.load(arrayBuffer);

                showProgress(60, 'Applying to pages...');
                const pages = pdf.getPages();
                pages.forEach(page => {
                    const { width, height } = page.getSize();
                    let x = width / 2;
                    let y = height / 2;

                    switch(position) {
                        case 'top-left': x = 50; y = height - 50; break;
                        case 'top-right': x = width - 100; y = height - 50; break;
                        case 'bottom-left': x = 50; y = 50; break;
                        case 'bottom-right': x = width - 100; y = 50; break;
                    }

                    page.drawText(text, {
                        x: x, y: y,
                        size: 30,
                        color: rgb(0.5, 0.5, 0.5),
                        opacity: opacity / 100,
                        rotate: position === 'diagonal' ? PDFLib.degrees(-45) : PDFLib.degrees(0)
                    });
                });

                showProgress(90, 'Saving...');
                const watermarkedPdf = await pdf.save();
                processedResult = new Blob([watermarkedPdf], { type: 'application/pdf' });

                showProgress(100, 'Complete!');
                setTimeout(() => {
                    hideProgress();
                    showToast('Watermark added successfully!', 'success');
                    document.getElementById('downloadBtn').style.display = 'inline-flex';
                }, 500);
            }, 300);
        }

        // ===== DOWNLOAD =====
        function downloadResult() {
            if (!processedResult) {
                showToast('No file to download', 'warning');
                return;
            }

            const url = URL.createObjectURL(processedResult);
            const a = document.createElement('a');
            a.href = url;

            const config = toolConfig[currentTool];
            let filename = 'processed';
            if (config) {
                filename = config.name.toLowerCase().replace(/\s+/g, '-');
            }

            if (processedResult.type === 'application/pdf') {
                a.download = filename + '.pdf';
            } else if (processedResult.type.startsWith('image/')) {
                a.download = filename + '.jpg';
            } else {
                a.download = filename + '.txt';
            }

            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
            URL.revokeObjectURL(url);

            showToast('Download started!', 'success');
        }

        // ===== MODAL UTILS =====
        function closeModal(id) {
            document.getElementById(id).classList.remove('active');
        }

        document.querySelectorAll('.modal-overlay').forEach(overlay => {
            overlay.addEventListener('click', (e) => {
                if (e.target === overlay) overlay.classList.remove('active');
            });
        });

        // ===== DRAG & DROP =====
        const uploadZone = document.getElementById('uploadZone');
        uploadZone.addEventListener('dragover', (e) => { e.preventDefault(); uploadZone.classList.add('dragover'); });
        uploadZone.addEventListener('dragleave', () => uploadZone.classList.remove('dragover'));
        uploadZone.addEventListener('drop', (e) => {
            e.preventDefault();
            uploadZone.classList.remove('dragover');
            const files = Array.from(e.dataTransfer.files);
            const config = toolConfig[currentTool];
            if (!config) return;
            files.forEach(file => {
                uploadedFiles.push(file);
                addFileToList(file);
            });
            showToast(files.length + ' file(s) dropped', 'success');
            if (currentTool === 'excel-to-pdf' && files.length > 0) {
                processExcelFile(files[0]);
            }
        });

        // ===== KEYBOARD SHORTCUTS =====
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') {
                document.querySelectorAll('.modal-overlay').forEach(m => m.classList.remove('active'));
                closeSidebar();
            }
        });
    </script>
