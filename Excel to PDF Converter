<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PDF Master Pro - All-in-One PDF Toolkit</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <!-- Firebase SDK -->
    <script src="https://www.gstatic.com/firebasejs/10.7.1/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/10.7.1/firebase-auth-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/10.7.1/firebase-firestore-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/10.7.1/firebase-storage-compat.js"></script>
    <!-- PDF Libraries -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.31/jspdf.plugin.autotable.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdf-lib/1.17.1/pdf-lib.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
    <style>
        :root {
            --primary: #7c3aed; --primary-light: #a78bfa; --primary-dark: #5b21b6;
            --secondary: #06b6d4; --accent: #f472b6; --accent2: #fbbf24;
            --accent3: #34d399; --accent4: #fb7185; --accent5: #818cf8;
            --dark: #0f0a1e; --dark-light: #1a1433; --dark-lighter: #251d4a;
            --light: #f8f7ff; --gray: #94a3b8;
            --success: #22c55e; --warning: #f59e0b; --danger: #ef4444;
            --glass: rgba(255,255,255,0.06); --glass-border: rgba(255,255,255,0.1);
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Inter', sans-serif;
            background: var(--dark);
            color: var(--light);
            min-height: 100vh;
            overflow-x: hidden;
        }

        /* ===== ANIMATED BACKGROUND ===== */
        .bg-animation {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            z-index: -1; overflow: hidden;
            background: linear-gradient(135deg, #0f0a1e 0%, #1a0b2e 25%, #1e1b4b 50%, #1a1433 75%, #0f0a1e 100%);
        }
        .orb {
            position: absolute; border-radius: 50%;
            filter: blur(80px); opacity: 0.5;
            animation: orbFloat 15s infinite ease-in-out;
        }
        .orb-1 { width: 500px; height: 500px; background: radial-gradient(circle, #7c3aed, transparent 70%); top: -10%; left: -10%; animation-delay: 0s; }
        .orb-2 { width: 400px; height: 400px; background: radial-gradient(circle, #06b6d4, transparent 70%); top: 30%; right: -5%; animation-delay: -3s; }
        .orb-3 { width: 450px; height: 450px; background: radial-gradient(circle, #f472b6, transparent 70%); bottom: -15%; left: 20%; animation-delay: -6s; }
        .orb-4 { width: 350px; height: 350px; background: radial-gradient(circle, #fbbf24, transparent 70%); top: 60%; left: -5%; animation-delay: -9s; }
        .orb-5 { width: 300px; height: 300px; background: radial-gradient(circle, #34d399, transparent 70%); top: 10%; right: 30%; animation-delay: -12s; }
        @keyframes orbFloat {
            0%, 100% { transform: translate(0, 0) scale(1) rotate(0deg); }
            25% { transform: translate(50px, -30px) scale(1.1) rotate(5deg); }
            50% { transform: translate(-30px, 50px) scale(0.95) rotate(-3deg); }
            75% { transform: translate(20px, -20px) scale(1.05) rotate(2deg); }
        }
        .particles { position: fixed; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none; z-index: 0; }
        .particle {
            position: absolute; width: 4px; height: 4px;
            border-radius: 50%; animation: particleFloat 20s infinite;
        }
        @keyframes particleFloat {
            0% { transform: translateY(100vh) rotate(0deg); opacity: 0; }
            10% { opacity: 1; }
            90% { opacity: 1; }
            100% { transform: translateY(-10vh) rotate(720deg); opacity: 0; }
        }

        /* ===== SIDEBAR ===== */
        .sidebar {
            position: fixed; top: 0; left: 0; width: 320px; height: 100vh;
            background: rgba(15,10,30,0.97); backdrop-filter: blur(30px);
            border-right: 1px solid var(--glass-border); z-index: 1000;
            transform: translateX(-100%);
            transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            overflow-y: auto; padding: 20px 0;
        }
        .sidebar.open { transform: translateX(0); }
        .sidebar-overlay {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.6); backdrop-filter: blur(5px);
            z-index: 999; opacity: 0; visibility: hidden; transition: all 0.3s;
        }
        .sidebar-overlay.active { opacity: 1; visibility: visible; }
        .sidebar-header { padding: 0 20px 20px; border-bottom: 1px solid var(--glass-border); margin-bottom: 15px; }
        .sidebar-logo {
            display: flex; align-items: center; gap: 12px;
            font-size: 1.4rem; font-weight: 800;
            background: linear-gradient(135deg, var(--primary-light), var(--secondary));
            -webkit-background-clip: text; -webkit-text-fill-color: transparent;
        }
        .sidebar-logo i { font-size: 1.8rem; -webkit-text-fill-color: var(--primary); }
        .sidebar-section { margin-bottom: 8px; }
        .sidebar-section-title {
            padding: 12px 20px 8px; font-size: 0.7rem; font-weight: 700;
            text-transform: uppercase; letter-spacing: 2px; color: var(--gray);
            display: flex; align-items: center; gap: 8px;
        }
        .sidebar-section-title i { font-size: 0.8rem; }
        .sidebar-item {
            display: flex; align-items: center; gap: 12px;
            padding: 12px 20px; margin: 2px 10px; border-radius: 12px;
            cursor: pointer; transition: all 0.3s;
            color: rgba(255,255,255,0.7); font-size: 0.9rem; font-weight: 500;
        }
        .sidebar-item:hover { background: rgba(124,58,237,0.15); color: var(--light); }
        .sidebar-item.active {
            background: linear-gradient(135deg, rgba(124,58,237,0.3), rgba(6,182,212,0.2));
            color: var(--light); border: 1px solid rgba(124,58,237,0.3);
        }
        .sidebar-item i { width: 24px; text-align: center; font-size: 1rem; }
        .sidebar-item .item-icon {
            width: 36px; height: 36px; border-radius: 10px;
            display: flex; align-items: center; justify-content: center; font-size: 0.9rem;
        }
        .sidebar-item:hover .item-icon { transform: scale(1.1); }
        .icon-organize { background: linear-gradient(135deg, #f472b6, #db2777); }
        .icon-optimize { background: linear-gradient(135deg, #06b6d4, #0891b2); }
        .icon-convert-to { background: linear-gradient(135deg, #fbbf24, #d97706); }
        .icon-convert-from { background: linear-gradient(135deg, #34d399, #059669); }
        .icon-edit { background: linear-gradient(135deg, #818cf8, #6366f1); }
        .icon-security { background: linear-gradient(135deg, #fb7185, #e11d48); }
        .icon-intelligence { background: linear-gradient(135deg, #a78bfa, #7c3aed); }

        /* ===== HEADER ===== */
        .main-header {
            position: sticky; top: 0; z-index: 100;
            background: rgba(15,10,30,0.8); backdrop-filter: blur(20px);
            border-bottom: 1px solid var(--glass-border);
            padding: 15px 30px; display: flex;
            justify-content: space-between; align-items: center;
        }
        .header-left { display: flex; align-items: center; gap: 20px; }
        .hamburger {
            width: 44px; height: 44px; border-radius: 12px;
            background: var(--glass); border: 1px solid var(--glass-border);
            display: flex; flex-direction: column; align-items: center;
            justify-content: center; gap: 5px; cursor: pointer; transition: all 0.3s;
        }
        .hamburger:hover { background: rgba(124,58,237,0.2); border-color: var(--primary); }
        .hamburger span { width: 20px; height: 2px; background: var(--light); border-radius: 2px; transition: all 0.3s; }
        .hamburger:hover span { background: var(--primary-light); }
        .header-title {
            font-size: 1.3rem; font-weight: 700;
            background: linear-gradient(135deg, #fff, var(--primary-light));
            -webkit-background-clip: text; -webkit-text-fill-color: transparent;
        }
        .auth-section { display: flex; align-items: center; gap: 15px; }
        .user-profile {
            display: none; align-items: center; gap: 10px;
            padding: 8px 16px; background: var(--glass);
            border: 1px solid var(--glass-border); border-radius: 50px;
        }
        .user-profile img { width: 32px; height: 32px; border-radius: 50%; border: 2px solid var(--primary); }
        .user-profile span { font-size: 0.9rem; font-weight: 500; }
        .signout-btn {
            background: none; border: none; color: var(--gray); cursor: pointer;
            font-size: 0.85rem; padding: 4px 8px; border-radius: 6px; transition: all 0.2s;
        }
        .signout-btn:hover { color: var(--danger); background: rgba(239,68,68,0.1); }
        .login-btn {
            padding: 10px 24px; border-radius: 12px; border: none;
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            color: white; font-family: 'Inter', sans-serif; font-weight: 600;
            cursor: pointer; display: flex; align-items: center; gap: 8px;
            transition: all 0.3s; box-shadow: 0 4px 20px rgba(124,58,237,0.3);
        }
        .login-btn:hover { transform: translateY(-2px); box-shadow: 0 8px 30px rgba(124,58,237,0.4); }

        /* ===== MAIN CONTENT ===== */
        .main-content { padding: 30px; max-width: 1400px; margin: 0 auto; min-height: calc(100vh - 80px); }

        /* ===== HERO ===== */
        .hero-section { text-align: center; padding: 60px 20px 40px; }
        .hero-badge {
            display: inline-flex; align-items: center; gap: 8px;
            background: rgba(124,58,237,0.15); border: 1px solid rgba(124,58,237,0.3);
            padding: 8px 20px; border-radius: 50px; font-size: 0.85rem;
            color: var(--primary-light); margin-bottom: 25px; animation: pulse 2s infinite;
        }
        @keyframes pulse { 0%, 100% { box-shadow: 0 0 0 0 rgba(124,58,237,0.3); } 50% { box-shadow: 0 0 0 10px rgba(124,58,237,0); } }
        .hero-section h1 {
            font-size: 3.5rem; font-weight: 900; line-height: 1.1; margin-bottom: 20px;
            background: linear-gradient(135deg, #fff 0%, #a78bfa 30%, #06b6d4 60%, #f472b6 100%);
            -webkit-background-clip: text; -webkit-text-fill-color: transparent;
        }
        .hero-section p { font-size: 1.2rem; color: var(--gray); max-width: 600px; margin: 0 auto 40px; }

        /* ===== TOOL CARDS ===== */
        .tools-grid {
            display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 20px; margin-bottom: 40px;
        }
        .tool-card {
            background: var(--glass); border: 1px solid var(--glass-border);
            border-radius: 20px; padding: 30px; cursor: pointer;
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            position: relative; overflow: hidden;
        }
        .tool-card::before {
            content: ''; position: absolute; top: 0; left: 0;
            width: 100%; height: 4px; transform: scaleX(0); transition: transform 0.4s;
        }
        .tool-card:hover::before { transform: scaleX(1); }
        .tool-card:hover {
            transform: translateY(-8px); border-color: var(--primary);
            box-shadow: 0 25px 60px rgba(124,58,237,0.15);
        }
        .tool-card .tool-icon {
            width: 60px; height: 60px; border-radius: 16px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.5rem; margin-bottom: 18px; transition: transform 0.3s;
        }
        .tool-card:hover .tool-icon { transform: scale(1.1) rotate(-5deg); }
        .tool-card h3 { font-size: 1.1rem; font-weight: 700; margin-bottom: 8px; color: var(--light); }
        .tool-card p { font-size: 0.85rem; color: var(--gray); line-height: 1.5; }
        .tool-card .tool-tag {
            display: inline-block; padding: 4px 12px; border-radius: 20px;
            font-size: 0.7rem; font-weight: 600; text-transform: uppercase;
            letter-spacing: 1px; margin-top: 12px;
        }
        .theme-organize::before { background: linear-gradient(90deg, #f472b6, #db2777); }
        .theme-organize .tool-icon { background: linear-gradient(135deg, #f472b6, #db2777); }
        .theme-organize .tool-tag { background: rgba(244,114,182,0.15); color: #f472b6; }
        .theme-optimize::before { background: linear-gradient(90deg, #06b6d4, #0891b2); }
        .theme-optimize .tool-icon { background: linear-gradient(135deg, #06b6d4, #0891b2); }
        .theme-optimize .tool-tag { background: rgba(6,182,212,0.15); color: #06b6d4; }
        .theme-convert-to::before { background: linear-gradient(90deg, #fbbf24, #d97706); }
        .theme-convert-to .tool-icon { background: linear-gradient(135deg, #fbbf24, #d97706); }
        .theme-convert-to .tool-tag { background: rgba(251,191,36,0.15); color: #fbbf24; }
        .theme-convert-from::before { background: linear-gradient(90deg, #34d399, #059669); }
        .theme-convert-from .tool-icon { background: linear-gradient(135deg, #34d399, #059669); }
        .theme-convert-from .tool-tag { background: rgba(52,211,153,0.15); color: #34d399; }
        .theme-edit::before { background: linear-gradient(90deg, #818cf8, #6366f1); }
        .theme-edit .tool-icon { background: linear-gradient(135deg, #818cf8, #6366f1); }
        .theme-edit .tool-tag { background: rgba(129,140,248,0.15); color: #818cf8; }
        .theme-security::before { background: linear-gradient(90deg, #fb7185, #e11d48); }
        .theme-security .tool-icon { background: linear-gradient(135deg, #fb7185, #e11d48); }
        .theme-security .tool-tag { background: rgba(251,113,133,0.15); color: #fb7185; }
        .theme-intelligence::before { background: linear-gradient(90deg, #a78bfa, #7c3aed); }
        .theme-intelligence .tool-icon { background: linear-gradient(135deg, #a78bfa, #7c3aed); }
        .theme-intelligence .tool-tag { background: rgba(167,139,250,0.15); color: #a78bfa; }

        /* ===== WORKSPACE ===== */
        .workspace { display: none; animation: fadeIn 0.5s ease; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
        .workspace-header {
            display: flex; justify-content: space-between; align-items: center;
            margin-bottom: 25px; flex-wrap: wrap; gap: 15px;
        }
        .workspace-title {
            font-size: 1.5rem; font-weight: 800;
            display: flex; align-items: center; gap: 12px;
        }
        .workspace-title i {
            width: 48px; height: 48px; border-radius: 14px;
            display: flex; align-items: center; justify-content: center; font-size: 1.3rem;
        }

        /* ===== UPLOAD ZONE ===== */
        .upload-zone {
            border: 2px dashed var(--glass-border); border-radius: 24px;
            padding: 60px 40px; text-align: center; background: var(--glass);
            backdrop-filter: blur(10px); transition: all 0.4s; cursor: pointer;
            position: relative; overflow: hidden; margin-bottom: 25px;
        }
        .upload-zone::after {
            content: ''; position: absolute; top: -50%; left: -50%;
            width: 200%; height: 200%;
            background: radial-gradient(circle, rgba(124,58,237,0.08) 0%, transparent 60%);
            animation: rotate 10s linear infinite;
        }
        @keyframes rotate { to { transform: rotate(360deg); } }
        .upload-zone:hover, .upload-zone.dragover {
            border-color: var(--primary); background: rgba(124,58,237,0.05);
            transform: translateY(-3px); box-shadow: 0 20px 60px rgba(124,58,237,0.15);
        }
        .upload-zone i { font-size: 4rem; margin-bottom: 20px; display: block; position: relative; z-index: 1; }
        .upload-zone h3 { font-size: 1.4rem; margin-bottom: 10px; position: relative; z-index: 1; }
        .upload-zone p { color: var(--gray); margin-bottom: 20px; position: relative; z-index: 1; }
        .upload-zone .formats { display: inline-flex; gap: 8px; flex-wrap: wrap; justify-content: center; position: relative; z-index: 1; }
        .upload-zone .formats span { background: var(--dark-light); padding: 6px 14px; border-radius: 20px; font-size: 0.8rem; color: var(--primary-light); border: 1px solid var(--glass-border); }
        #fileInput { display: none; }

        /* ===== BUTTONS ===== */
        .btn {
            padding: 12px 28px; border-radius: 12px; border: none;
            font-family: 'Inter', sans-serif; font-weight: 600; font-size: 0.95rem;
            cursor: pointer; transition: all 0.3s; display: inline-flex; align-items: center; gap: 8px;
        }
        .btn-primary { background: linear-gradient(135deg, var(--primary), var(--primary-dark)); color: white; box-shadow: 0 4px 20px rgba(124,58,237,0.3); }
        .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 8px 30px rgba(124,58,237,0.4); }
        .btn-secondary { background: var(--dark-light); color: var(--light); border: 1px solid var(--glass-border); }
        .btn-secondary:hover { background: var(--dark-lighter); border-color: var(--primary); }
        .btn-success { background: linear-gradient(135deg, var(--accent3), #059669); color: white; box-shadow: 0 4px 20px rgba(52,211,153,0.3); }
        .btn-success:hover { transform: translateY(-2px); box-shadow: 0 8px 30px rgba(52,211,153,0.4); }
        .btn-danger { background: linear-gradient(135deg, var(--accent4), #e11d48); color: white; }
        .btn-warning { background: linear-gradient(135deg, var(--accent2), #d97706); color: white; }

        /* ===== PROGRESS OVERLAY ===== */
        .progress-overlay {
            display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(15,10,30,0.95); z-index: 2000;
            justify-content: center; align-items: center; flex-direction: column; gap: 25px;
        }
        .progress-overlay.active { display: flex; }
        .progress-ring-container { width: 150px; height: 150px; position: relative; }
        .progress-ring-container svg { transform: rotate(-90deg); width: 100%; height: 100%; }
        .progress-ring-container circle { fill: none; stroke-width: 6; }
        .progress-ring-container .bg { stroke: var(--dark-lighter); }
        .progress-ring-container .progress { stroke: url(#gradient1); stroke-linecap: round; stroke-dasharray: 377; stroke-dashoffset: 377; transition: stroke-dashoffset 0.5s; }
        .progress-percent { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); font-size: 1.8rem; font-weight: 800; color: var(--light); }
        .progress-label { color: var(--gray); font-size: 1.1rem; }

        /* ===== TOAST ===== */
        .toast-container { position: fixed; top: 100px; right: 30px; z-index: 3000; display: flex; flex-direction: column; gap: 10px; }
        .toast {
            padding: 16px 24px; border-radius: 14px; color: white; font-weight: 600;
            display: flex; align-items: center; gap: 12px;
            animation: slideInRight 0.4s, fadeOutRight 0.4s 3.5s forwards;
            backdrop-filter: blur(10px); border: 1px solid rgba(255,255,255,0.1);
            box-shadow: 0 10px 40px rgba(0,0,0,0.3); min-width: 300px;
        }
        @keyframes slideInRight { from { transform: translateX(100px); opacity: 0; } to { transform: translateX(0); opacity: 1; } }
        @keyframes fadeOutRight { to { opacity: 0; transform: translateX(100px); } }
        .toast.success { background: rgba(34,197,94,0.95); }
        .toast.error { background: rgba(239,68,68,0.95); }
        .toast.info { background: rgba(124,58,237,0.95); }
        .toast.warning { background: rgba(245,158,11,0.95); }

        /* ===== FILE LIST ===== */
        .file-list { display: flex; flex-direction: column; gap: 8px; margin: 15px 0; max-height: 200px; overflow-y: auto; }
        .file-list-item {
            display: flex; align-items: center; justify-content: space-between;
            padding: 12px 16px; background: var(--dark); border-radius: 12px; border: 1px solid var(--glass-border);
        }
        .file-list-item .file-info { display: flex; align-items: center; gap: 10px; }
        .file-list-item i { font-size: 1.2rem; }
        .file-list-item .remove-btn { background: none; border: none; color: var(--danger); cursor: pointer; font-size: 1rem; padding: 4px; border-radius: 6px; transition: all 0.2s; }
        .file-list-item .remove-btn:hover { background: rgba(239,68,68,0.1); }

        /* ===== SETTINGS ===== */
        .settings-panel { display: none; background: var(--glass); border: 1px solid var(--glass-border); border-radius: 20px; padding: 25px; margin-bottom: 20px; }
        .settings-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px; }
        .setting-group h4 { color: var(--primary-light); margin-bottom: 15px; font-size: 0.95rem; }
        .setting-item { margin-bottom: 12px; }
        .setting-item label { display: block; color: var(--gray); font-size: 0.85rem; margin-bottom: 6px; }
        .setting-item input, .setting-item select { width: 100%; padding: 10px 14px; border-radius: 10px; border: 1px solid var(--glass-border); background: var(--dark-light); color: var(--light); font-family: 'Inter', sans-serif; }
        .setting-item input[type="color"] { width: 50px; height: 40px; padding: 2px; }
        .setting-item.checkbox { display: flex; align-items: center; gap: 10px; }
        .setting-item.checkbox label { margin-bottom: 0; }
        .setting-item input[type="checkbox"] { width: 20px; height: 20px; accent-color: var(--primary); }

        /* ===== MODAL ===== */
        .modal-overlay {
            display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(15,10,30,0.9); z-index: 1500;
            justify-content: center; align-items: center; backdrop-filter: blur(10px);
        }
        .modal-overlay.active { display: flex; }
        .modal-box {
            background: var(--dark-light); border: 1px solid var(--glass-border);
            border-radius: 24px; padding: 35px; max-width: 500px; width: 90%;
            animation: modalPop 0.3s ease;
        }
        @keyframes modalPop { from { transform: scale(0.9); opacity: 0; } to { transform: scale(1); opacity: 1; } }
        .modal-box h3 { font-size: 1.3rem; margin-bottom: 20px; display: flex; align-items: center; gap: 10px; }
        .modal-actions { display: flex; gap: 12px; justify-content: flex-end; margin-top: 25px; }

        /* ===== PAGE RANGE ===== */
        .page-range-input { display: flex; gap: 10px; align-items: center; margin: 15px 0; }
        .page-range-input input { width: 80px; padding: 10px; border-radius: 10px; border: 1px solid var(--glass-border); background: var(--dark); color: var(--light); text-align: center; }

        /* ===== PDF PREVIEW ===== */
